                    sL.Font = Enum.Font.SourceSans; sL.TextSize = 11
                    sL.BackgroundTransparency = 1; sL.TextStrokeTransparency = 0.3
                end
                local bb = head and head:FindFirstChild("_mel_bb"); if not bb then continue end
                local nL, sL = bb:FindFirstChild("N"), bb:FindFirstChild("S")
                local myHRP  = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
                local thHRP  = char:FindFirstChild("HumanoidRootPart")
                if nL then
                    if isBeast(p) then nL.Text = "BEAST: "..p.Name; nL.TextColor3 = Color3.fromRGB(255,80,80)
                    else nL.Text = p.Name; nL.TextColor3 = Color3.fromRGB(200,220,255) end
                end
                if sL then
                    if isBeast(p) then sL.Text = ""
                    elseif isCaptured(p) then sL.Text = "⛓ Capturado"; sL.TextColor3 = Color3.fromRGB(255,200,80)
                    elseif hasEscaped(p) then sL.Text = "✓ Escapó"; sL.TextColor3 = Color3.fromRGB(80,255,160)
                    elseif myHRP and thHRP then
                        sL.Text = math.floor((myHRP.Position - thHRP.Position).Magnitude).."m"
                        sL.TextColor3 = Color3.fromRGB(160,210,255)
                    else sL.Text = "" end
                end
            end
        end)
    else
        RS_svc:UnbindFromRenderStep("MEL_PESP")
        for _, p in pairs(Players:GetPlayers()) do
            if p.Character then
                local h = p.Character:FindFirstChild("_mel_hl"); if h then h:Destroy() end
                local head = p.Character:FindFirstChild("Head")
                if head then local b = head:FindFirstChild("_mel_bb"); if b then b:Destroy() end end
            end
        end
    end
end)

