-- No-Fail hook
local function installHook()
    if hookDone then return end
    if not (getnamecallmethod and getrawmetatable) then return end
    local mt = getrawmetatable(game)
    pcall(function()
        if setreadonly then setreadonly(mt, false)
        elseif makewriteable then makewriteable(mt) end
    end)
    local old = mt.__namecall
    local wrap = function(self, ...)
        local a = {...}
        if FTF.noFail and getnamecallmethod() == "FireServer" and self == RemoteEvent then
            if a[1] == "SetPlayerMinigameResult" then a[2] = true end
        end
        return old(self, table.unpack(a))
    end
    mt.__namecall = (newcclosure and newcclosure(wrap)) or wrap
    hookDone = true
end
pcall(installHook)

