Toggle("Fullbright", Color3.fromRGB(255, 255, 100), function(v)
    FTF.fullBright = v
    if v then
        FB_orig = {
            Brightness=Lighting.Brightness, ClockTime=Lighting.ClockTime,
            FogEnd=Lighting.FogEnd, FogStart=Lighting.FogStart,
            GlobalShadows=Lighting.GlobalShadows,
            OutdoorAmbient=Lighting.OutdoorAmbient, Ambient=Lighting.Ambient
        }
        local atm = Lighting:FindFirstChildOfClass("Atmosphere")
        if atm then FB_orig.AtmD = atm.Density end
        task.spawn(function()
            while FTF.fullBright do
                local a = Lighting:FindFirstChildOfClass("Atmosphere"); if a then a.Density = 0 end
                Lighting.Brightness = 1.5; Lighting.ClockTime = 14; Lighting.FogEnd = 100000
                Lighting.FogStart = 0; Lighting.GlobalShadows = false
                Lighting.OutdoorAmbient = Color3.fromRGB(100,100,100)
                Lighting.Ambient        = Color3.fromRGB(80,80,80)
                task.wait()
            end
        end)
    else
        if FB_orig then
            task.wait(0.25)
            for prop, val in pairs(FB_orig) do
                if prop == "AtmD" then
                    local a = Lighting:FindFirstChildOfClass("Atmosphere"); if a then a.Density = val end
                else Lighting[prop] = val end
            end
        end
    end
end)

