    lbl.TextSize       = 12
    lbl.TextColor3     = Color3.fromRGB(210, 210, 255)
    lbl.TextXAlignment = Enum.TextXAlignment.Left
    lbl.BackgroundTransparency = 1

    local vLbl = Instance.new("TextLabel", topF)
    vLbl.Size           = UDim2.new(0.35, 0, 1, 0)
    vLbl.Position       = UDim2.new(0.65, 0, 0, 0)
    vLbl.Text           = tostring(val) .. unit
    vLbl.Font           = Enum.Font.SourceSansBold
    vLbl.TextSize       = 12
    vLbl.TextColor3     = Color3.fromRGB(160, 120, 255)
    vLbl.TextXAlignment = Enum.TextXAlignment.Right
    vLbl.BackgroundTransparency = 1

    local track = Instance.new("Frame", row)
    track.Size             = UDim2.new(1, -16, 0, 5)
    track.Position         = UDim2.new(0, 8, 0, 30)
    track.BackgroundColor3 = Color3.fromRGB(40, 36, 60)
    track.BorderSizePixel  = 0
    Instance.new("UICorner", track).CornerRadius = UDim.new(0, 3)

    local pct  = (val - minV) / math.max(maxV - minV, 1)
    local fill = Instance.new("Frame", track)
    fill.Size             = UDim2.new(pct, 0, 1, 0)
    fill.BackgroundColor3 = Color3.fromRGB(100, 60, 200)
    fill.BorderSizePixel  = 0
    Instance.new("UICorner", fill).CornerRadius = UDim.new(0, 3)

    local knob = Instance.new("Frame", track)
    knob.Size             = UDim2.fromOffset(14, 14)
    knob.Position         = UDim2.new(pct, -7, 0.5, -7)
    knob.BackgroundColor3 = Color3.fromRGB(200, 170, 255)
    knob.BorderSizePixel  = 0
    Instance.new("UICorner", knob).CornerRadius = UDim.new(1, 0)

    local drag = false
    local hit  = Instance.new("TextButton", row)
    hit.Size     = UDim2.new(1, -16, 0, 22)
    hit.Position = UDim2.new(0, 8, 0, 22)
    hit.BackgroundTransparency = 1
    hit.Text     = ""
    hit.ZIndex   = 5

    local function upd(x)
        local ap = track.AbsolutePosition.X
        local az = track.AbsoluteSize.X
        if az == 0 then return end
        local r = math.clamp((x - ap) / az, 0, 1)
        val = math.floor(minV + r * (maxV - minV))
        vLbl.Text     = tostring(val) .. unit
        fill.Size     = UDim2.new(r, 0, 1, 0)
        knob.Position = UDim2.new(r, -7, 0.5, -7)
        if onChange then onChange(val) end
    end

    hit.MouseButton1Down:Connect(function()
        drag = true
        local c; c = RS_svc.Heartbeat:Connect(function()
            if drag then upd(Mouse.X) else c:Disconnect() end
        end)
    end)
    hit.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.Touch then
            drag = true; upd(i.Position.X)
        end
    end)
    UIS.InputChanged:Connect(function(i)
        if drag and i.UserInputType == Enum.UserInputType.Touch then upd(i.Position.X) end
    end)
    UIS.InputEnded:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
            drag = false
        end
    end)
end

