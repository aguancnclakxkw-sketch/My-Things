                        hl.FillColor = Color3.fromRGB(100,180,255); hl.OutlineColor = Color3.fromRGB(160,210,255)
                    end
                end
                local head = char:FindFirstChild("Head")
                if head and not head:FindFirstChild("_mel_bb") then
                    local bb = Instance.new("BillboardGui", head); bb.Name = "_mel_bb"
                    bb.Size = UDim2.fromOffset(150, 44); bb.StudsOffset = Vector3.new(0, 2.8, 0); bb.AlwaysOnTop = true
                    local nL = Instance.new("TextLabel", bb); nL.Name = "N"
                    nL.Size = UDim2.new(1,0,0.55,0); nL.Font = Enum.Font.SourceSansBold; nL.TextSize = 13
                    nL.BackgroundTransparency = 1; nL.TextStrokeTransparency = 0.3
                    local sL = Instance.new("TextLabel", bb); sL.Name = "S"
