local RemoteEvent = RS:FindFirstChild("RemoteEvent") or RS:WaitForChild("RemoteEvent", 5)

local function getMap()
    local ov = RS:FindFirstChild("CurrentMap", true)
    if ov and ov:IsA("ObjectValue") and ov.Value then return ov.Value end
    for _, o in pairs(WS:GetDescendants()) do
        if o.Name == "FreezePod" then return o.Parent end
    end
end
local function isBeast(p)
    local s = p:FindFirstChild("TempPlayerStatsModule")
    return s and s:FindFirstChild("IsBeast") and s.IsBeast.Value == true
end
local function isCaptured(p)
    local s = p:FindFirstChild("TempPlayerStatsModule")
    return s and s:FindFirstChild("Captured") and s.Captured.Value == true
end
local function hasEscaped(p)
    local s = p:FindFirstChild("TempPlayerStatsModule")
    return s and s:FindFirstChild("Escaped") and s.Escaped.Value == true
end
local function getRoot(char)
    if not (char and char.Parent) then return end
    return char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("Torso")
end
local function getPodEvent(map)
    if not map then return end
    for _, o in pairs(map:GetChildren()) do
        if o.Name ~= "FreezePod" then continue end
        local pt = o:FindFirstChild("PodTrigger", true)
        if pt then
            local ct = pt:FindFirstChild("CapturedTorso")
            local ev = pt:FindFirstChild("Event")
            if ct and ev and ct.Value then return ev end
        end
    end
end
local function getBeastHEvent()
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LP and p.Character and p.Character:FindFirstChild("Hammer") then
            return p.Character:FindFirstChild("HammerEvent", true)
        end
    end
end
local function getBeastPEvent()
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LP and p.Character and p.Character:FindFirstChild("BeastPowers") then
            return p.Character:FindFirstChild("PowersEvent", true)
        end
    end
end

